# =============================================
# TL ELECT SERVICES — Variables d'environnement
# Copier ce fichier en .env et modifier les valeurs
# =============================================

# Port du serveur (défaut: 3000)
PORT=3000

# Secret JWT — CHANGE EN PRODUCTION (chaîne longue et aléatoire)
JWT_SECRET=tl_elect_jwt_secret_CHANGE_MOI_EN_PRODUCTION_2024

# Origine autorisée pour CORS (ton domaine frontend)
# Exemple: https://monsite.com  ou  * pour tout autoriser (dev uniquement)
ALLOWED_ORIGIN=*
